rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: Ensure kycStatus field is not modified by client
    // kycStatus is authoritative and can only be set by Cloud Functions (Admin SDK)
    function kycStatusUnchanged() {
      return !('kycStatus' in resource.data)
        ? !request.resource.data.keys().hasAny(['kycStatus'])
        : request.resource.data.kycStatus == resource.data.kycStatus;
    }

    // Helper: Ensure accountBlocked field and metadata are not modified by client
    // accountBlocked can only be set by Cloud Functions (Admin SDK)
    function accountBlockedUnchanged() {
      return (!('accountBlocked' in resource.data)
        ? !request.resource.data.keys().hasAny(['accountBlocked', 'accountBlockedAt', 'accountBlockedBy', 'accountUnblockedAt'])
        : request.resource.data.accountBlocked == resource.data.accountBlocked
          && request.resource.data.get('accountBlockedAt', null) == resource.data.get('accountBlockedAt', null)
          && request.resource.data.get('accountBlockedBy', null) == resource.data.get('accountBlockedBy', null)
          && request.resource.data.get('accountUnblockedAt', null) == resource.data.get('accountUnblockedAt', null));
    }

    // Helper: Ensure pinHash and pinSalt fields are not modified by client
    // pinHash and pinSalt can only be set by Cloud Functions (Admin SDK)
    function pinHashUnchanged() {
      return (!('pinHash' in resource.data)
        ? !request.resource.data.keys().hasAny(['pinHash', 'pinSalt'])
        : request.resource.data.pinHash == resource.data.pinHash)
        && (!('pinSalt' in resource.data)
        ? !request.resource.data.keys().hasAny(['pinSalt'])
        : request.resource.data.pinSalt == resource.data.pinSalt);
    }

    // Helper: Ensure role field is not modified by client
    // role can only be set by Cloud Functions (Admin SDK) via admin promote/demote
    function roleUnchanged() {
      return !('role' in resource.data)
        ? !request.resource.data.keys().hasAny(['role'])
        : request.resource.data.role == resource.data.role;
    }

    // Phase 4b: Verification flags are server-only.
    // The server (Admin SDK) writes these atomically when KYC or phone
    // verification completes. Client writes are blocked.

    function kycCompletedUnchanged() {
      return !('kycCompleted' in resource.data)
        ? !request.resource.data.keys().hasAny(['kycCompleted'])
        : request.resource.data.kycCompleted == resource.data.kycCompleted;
    }

    function kycVerifiedUnchanged() {
      return !('kycVerified' in resource.data)
        ? !request.resource.data.keys().hasAny(['kycVerified'])
        : request.resource.data.kycVerified == resource.data.kycVerified;
    }

    function phoneVerifiedUnchanged() {
      return !('phoneVerified' in resource.data)
        ? !request.resource.data.keys().hasAny(['phoneVerified'])
        : request.resource.data.phoneVerified == resource.data.phoneVerified;
    }

    function emailVerifiedUnchanged() {
      return !('emailVerified' in resource.data)
        ? !request.resource.data.keys().hasAny(['emailVerified'])
        : request.resource.data.emailVerified == resource.data.emailVerified;
    }

    // Users collection - own data only
    match /users/{userId} {
      allow read: if isOwner(userId);
      // Allow create without kycStatus (new user signup)
      allow create: if isOwner(userId) && !request.resource.data.keys().hasAny(['kycStatus', 'pinHash', 'pinSalt', 'role']);
      // Phase 4b: verification flags (kycCompleted, kycVerified, phoneVerified,
      // emailVerified) are server-only via Admin SDK. Client cannot create or
      // modify them.
      allow update: if isOwner(userId)
                       && kycStatusUnchanged()
                       && accountBlockedUnchanged()
                       && pinHashUnchanged()
                       && roleUnchanged()
                       && kycCompletedUnchanged()
                       && kycVerifiedUnchanged()
                       && phoneVerifiedUnchanged()
                       && emailVerifiedUnchanged();
      allow delete: if false;

 // Transactions - read only from client (all writes via Cloud Functions Admin SDK)
      match /transactions/{txId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }

      // Notifications — user can read, mark as read (update), and delete
      match /notifications/{notifId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if false;
      }

      // FCM tokens — user can manage their own device tokens
      match /fcm_tokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }

      // Linked bank accounts — owner can manage their own saved bank accounts
      // Used as reference data for withdrawals (bank name, account number, account name)
      match /linkedBankAccounts/{accountId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
        allow update: if false;
      }

      // KYC documents — client can write their submission metadata;
      // sensitive fields (smileIdVerified, verified*, smileIdResultCode) are
      // server-only and cannot be set/modified by the client.
      match /kyc/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && (!('smileIdVerified' in request.resource.data) || request.resource.data.smileIdVerified == false)
          && !request.resource.data.keys().hasAny(['verifiedData', 'smileIdResultCode', 'verifiedAt', 'verifiedBy']);
        allow update: if isOwner(userId)
          && (!('smileIdVerified' in request.resource.data) || request.resource.data.smileIdVerified == resource.data.get('smileIdVerified', false))
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['verifiedData', 'smileIdResultCode', 'verifiedAt', 'verifiedBy']);
        allow delete: if false;
      }
    }

    // Wallets — read own only; all writes via Cloud Functions (Admin SDK).
    match /wallets/{walletId} {
      allow read: if isAuthenticated() && request.auth.uid == walletId;
      // Writes: server-only. Wallets are created exclusively by Cloud
      // Functions (createWalletForUser, completeKycVerification) AFTER
      // KYC verification (kycStatus == 'verified'), via the Admin SDK
      // which bypasses these rules. The previous create rule allowed any
      // authed user to create their own zero-balance wallet without a
      // KYC check, leaving a defense-in-depth gap even though the Cloud
      // Function correctly enforces KYC at creation time. Cross-check
      // audit section 4.8 (2026-05-21) flagged this. Resolved by
      // forbidding all client writes, consistent with how every other
      // money-touching collection in this file is structured.
      //
      // Verified no client-side wallet creates exist in lib/ — all
      // references are reads/queries via .get()/.snapshots()/.where().
      // The .delete() in lib/core/services/user_service.dart's
      // deleteAccount() was already blocked by the previous
      // `allow update, delete: if false` rule; behavior unchanged.
      allow create, update, delete: if false;

      // Phase 5i: platform-owned dispute recovery escrow wallets.
      // Path pattern: wallets/dispute_recovery_<CURRENCY>
      // Only Cloud Functions (Admin SDK) can read or write. No client access.
      // The existing read rule above already denies clients (auth.uid never
      // matches 'dispute_recovery_<CURRENCY>'); this rule is belt-and-braces
      // documentation of intent.
      allow read, write: if walletId.matches('dispute_recovery_.*') && false;

      // Platform wallet subcollections — Cloud Functions only
      match /balances/{docId} {
        allow read, write: if false;
      }
      match /fees/{docId} {
        allow read, write: if false;
      }
      match /withdrawals/{docId} {
        allow read, write: if false;
      }
    }

    // Wallet holds - Cloud Functions only.
    // Holds reserve money in a user's wallet for a future commitment
    // (e.g. Shop Afrik pay-on-delivery orders). Clients never read or
    // write hold documents directly. All hold operations (createHold,
    // releaseHold, convertHoldToTransfer, getHoldStatus, listHoldsForWallet)
    // go through callable Cloud Functions which handle authentication,
    // authorization, atomicity, and audit logging.
    match /wallet_holds/{holdId} {
      allow read, write: if false;
    }

    // Exchange rates - read only
    match /exchange_rates/{rateId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // App config - read only
    match /app_config/{doc} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Rate limits - Cloud Functions only
    match /rate_limits/{userId} {
      allow read, write: if false;
    }

    // Audit logs - Cloud Functions only (no client access)
    match /audit_logs/{logId} {
      allow read, write: if false;
    }

    // Payments - Cloud Functions only (for idempotency tracking)
    match /payments/{paymentId} {
      allow read, write: if false;
    }

    // Idempotency keys - Cloud Functions only (prevents duplicate financial operations)
    match /idempotency_keys/{keyId} {
      allow read, write: if false;
    }

    // MoMo transactions - Cloud Functions only
    match /momo_transactions/{txId} {
      allow read, write: if false;
    }

    // Withdrawals - Cloud Functions only
    match /withdrawals/{withdrawalId} {
      allow read, write: if false;
    }

    // QR nonces - Cloud Functions only (replay protection)
    match /qr_nonces/{nonceId} {
      allow read, write: if false;
    }

    // Admin activity - Cloud Functions only
    match /admin_activity/{docId} {
      allow read, write: if false;
    }

    // Fraud alerts - Cloud Functions only
    match /fraud_alerts/{docId} {
      allow read, write: if false;
    }

    // Recovery OTPs - Cloud Functions only
    match /recovery_otps/{docId} {
      allow read, write: if false;
    }

    // Flagged transactions - Cloud Functions only (fraud review)
    match /flagged_transactions/{txId} {
      allow read, write: if false;
    }

    // Pending transactions - Cloud Functions only (amount cross-validation)
    match /pending_transactions/{txId} {
      allow read, write: if false;
    }

    // admin_users — Cloud Functions only.
    // Map of admin staff by email. Written by adminPromoteUser, adminDemoteUser,
    // promoteSuperAdmin, updateSuperAdminAllowlist. Read by adminListAdmins.
    // Clients never access directly.
    match /admin_users/{email} {
      allow read, write: if false;
    }

    // admin_bootstrap_config — Cloud Functions only.
    // Stores the super_admin email allowlist at /admin_bootstrap_config/allowed_emails.
    // Written by setupSuperAdmin and updateSuperAdminAllowlist, read by
    // promoteSuperAdmin and adminGetAllowlist. Never accessed by clients.
    match /admin_bootstrap_config/{docId} {
      allow read, write: if false;
    }

    // Business wallets — read access for listed owner users, writes via Cloud Functions only.
    // Each business wallet doc contains an ownerUsers map of {uid: role}.
    // Authorized users can read their business wallet metadata.
    // All mutations (create, update, withdraw, refund) go through Cloud Functions.
    match /businessWallets/{businessId} {
      allow read: if isAuthenticated()
        && resource.data.ownerUsers[request.auth.uid] != null;
      allow write: if false;
    }

    // platform_transfer_proposals — Cloud Functions only.
    // Dual-signature workflow for platform transfers: finance proposes, admin_manager
    // approves, super_admin enters Paystack OTP. Written only by:
    //   adminProposeTransfer, adminApproveTransfer, adminRejectTransfer,
    //   adminCancelProposal, adminEmergencyTransfer, adminFinalizeTransfer,
    //   autoExpireProposals, autoExpireOtpTransfers
    // Read via adminListTransferProposals. Clients never access directly.
    match /platform_transfer_proposals/{proposalId} {
      allow read, write: if false;
    }

    // email_queue — Cloud Functions only.
    // Holds emails that failed to send via Resend. Retried by processEmailQueue
    // scheduled CF. After 3 failed attempts, marked failed_permanently.
    match /email_queue/{queueId} {
      allow read, write: if false;
    }

    // sms_queue — Cloud Functions only.
    // Holds SMS messages that failed to send via Africa's Talking.
    // Retried by processSmsQueue scheduled CF.
    match /sms_queue/{queueId} {
      allow read, write: if false;
    }

    // blocked_finance_users — Cloud Functions only.
    // Tracks finance users blocked from new proposals due to overdue evidence.
    // Populated by markFinanceBlockedScheduled after 21 days of overdue evidence.
    // Cleared by adminCloseProposal when all overdue proposals are resolved.
    match /blocked_finance_users/{uid} {
      allow read, write: if false;
    }

    // disputes — Cloud Functions only. NO direct client reads.
    //
    // All client access goes through callables:
    //   user app:        userGetMyDisputes, userViewDispute
    //   admin dashboard: adminListDisputes, adminAssignDispute,
    //                    adminSubmitInvestigation, adminProposeDisputeRelease,
    //                    adminConfirmDisputeRelease, adminRejectDisputeRelease,
    //                    adminManagerDecision, adminSuperAdminDisputeDecision
    //
    // The previous filer+recipient READ carve-out exposed admin-internal fields
    // (releaseProposal.proposedBy, managerNotes, reviewingManager,
    // superAdminDecidedBy, releaseRejectionReason, _awaitingMoneyMovement,
    // _recoveryWatchActive) that userViewDispute deliberately sanitizes before
    // returning to clients. The Phase 5i design treats hiding the proposer
    // identity and admin notes as a hard security boundary; this rule enforces
    // it. See cross-check audit section 4.5 (2026-05-21).
    //
    // Verified clean on 2026-05-21: zero direct Firestore reads on disputes
    // from lib/ or admin-dashboard/src/. Do NOT re-add the filer+recipient
    // carve-out without re-confirming no client-side direct reads exist.
    match /disputes/{disputeId} {
      allow read, write: if false;
    }

    // wallet_blocks — Cloud Functions only
    match /wallet_blocks/{blockId} {
      allow read, write: if false;
    }

    // dispute_history — Cloud Functions only
    match /dispute_history/{userUid} {
      allow read, write: if false;
    }

    // wallet_debts — Cloud Functions only (filer + recipient can READ their own debts)
    match /wallet_debts/{debtId} {
      allow read: if request.auth != null
        && (resource.data.recipientUid == request.auth.uid
            || resource.data.filerUid == request.auth.uid);
      allow write: if false;
    }

    // debt_recoveries — Cloud Functions only (filer + recipient can READ their own)
    match /debt_recoveries/{recoveryId} {
      allow read: if request.auth != null
        && (resource.data.recipientUid == request.auth.uid
            || resource.data.filerUid == request.auth.uid);
      allow write: if false;
    }

    // compliance_archive — Cloud Functions only. NO client access at all.
    //
    // Stores soft-deleted user records for 7-year AML/fraud retention.
    // All writes happen via deleteUserData (Cloud Function, Admin SDK).
    // Phase 1: authorized admin roles read via the Firebase console.
    // Phase 2 will add admin Cloud Functions for searchable lookups with
    // tiered field visibility (admin_supervisor sees limited fields;
    // finance, admin_manager, super_admin see everything).
    match /compliance_archive/{userId} {
      allow read, write: if false;

      match /{subcoll}/{doc} {
        allow read, write: if false;
      }
    }
  }
}
